# ─── Shopify Storefront API ──────────────────────────────────────────
# All cart and checkout operations route through these credentials.
# Get tokens from the Headless sales channel (NOT the legacy "Develop apps"
# path, which has been deprecated for new apps as of January 1, 2026).
#
# Setup:
#   1. Shopify Admin → Apps → Shopify App Store → install "Headless"
#   2. From Sales channels → Headless → click "Add storefront"
#   3. The storefront page shows two tokens: Public + Private
#   4. Set Storefront API permissions on that storefront to include:
#      - Read products and collections
#      - Read product inventory
#      - Read and write checkouts (cart)

# Your *.myshopify.com domain (NOT the customer-facing domain).
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com

# PRIVATE token — preferred for server-side calls (cart creation, checkout).
# Higher rate limits, treated as secret. NEVER prefix with NEXT_PUBLIC_.
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# PUBLIC token — used as fallback or for client-side reads.
# Safe to expose in browser bundles.
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# API version. Shopify ships quarterly. Latest stable as of May 2026.
SHOPIFY_STOREFRONT_API_VERSION=2026-01

# ─── Site URL ────────────────────────────────────────────────────────
# Used for canonical URLs, sitemap, and OG metadata.
NEXT_PUBLIC_SITE_URL=https://enviroaqua.com.au

# Phone, email, address, hours, ABN etc. live in lib/business.ts as the
# single source of truth — not in env vars. Change them there.
